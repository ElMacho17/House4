<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verificador Hardy - Pro Bounce Edition</title>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        :root { 
            --inst-blue: #1e3a8a;
            --inst-yellow: #facc15;
            --success: #22c55e; 
            --warning: #f59e0b;
            --error: #ef4444; 
        }

        body, html { 
            margin: 0; padding: 0; width: 100%; height: 100%;
            font-family: 'Segoe UI', system-ui, sans-serif;
            overflow: hidden;
            background: #020617;
            display: flex; align-items: center; justify-content: center;
        }

        /* Fondo Animado */
        .bg-animated {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at center, #1e3a8a 0%, #020617 100%);
            animation: pulseBg 8s ease-in-out infinite;
            z-index: -1;
        }

        @keyframes pulseBg {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.2); opacity: 1; }
        }

        /* Escáner con Rebote al aparecer */
        .container {
            text-align: center;
            z-index: 10;
            width: 90%;
            max-width: 400px;
            animation: bounceInUp 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        #reader { 
            border-radius: 35px; 
            overflow: hidden; 
            border: 6px solid var(--inst-yellow);
            box-shadow: 0 0 40px rgba(250, 204, 21, 0.2);
            background: black;
        }

        /* Overlay con Blur */
        #overlay {
            display: none; 
            position: fixed; 
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 100; 
            align-items: center; justify-content: center;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }

        /* Carta de Resultado con Efecto Bounce/Scale */
        .result-card {
            background: white;
            padding: 40px;
            border-radius: 40px;
            text-align: center;
            width: 80%;
            max-width: 340px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            border-bottom: 10px solid var(--inst-blue);
            animation: cardBounce 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        @keyframes cardBounce {
            0% { transform: scale(0.3); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        @keyframes bounceInUp {
            0% { transform: translateY(500px); opacity: 0; }
            60% { transform: translateY(-30px); opacity: 1; }
            80% { transform: translateY(10px); }
            100% { transform: translateY(0); }
        }

        .nombre-display { 
            font-size: 2.2rem; 
            font-weight: 900; 
            color: var(--inst-blue);
            margin: 15px 0;
            text-transform: uppercase;
        }

        .estado-badge {
            padding: 12px;
            border-radius: 20px;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 25px;
            font-size: 0.9rem;
        }

        .btn-confirm { 
            padding: 20px; 
            border-radius: 20px; 
            border: none; 
            font-weight: 900; 
            cursor: pointer; 
            background: var(--inst-blue);
            color: white;
            width: 100%;
            font-size: 1.1rem;
            transition: 0.2s;
        }

        .btn-confirm:active { transform: scale(0.9); }

        h2 { color: white; margin-bottom: 20px; letter-spacing: 2px; }
    </style>
</head>
<body>

    <div class="bg-animated"></div>

    <div class="container">
        <h2>VERIFICADOR <span style="color: var(--inst-yellow)">HARDY</span></h2>
        <div id="reader"></div>
    </div>

    <div id="overlay">
        <div class="result-card" id="card">
            <div id="icon" style="font-size: 100px; margin-bottom: 10px;"></div>
            <div class="nombre-display" id="resNombre"></div>
            <div id="resEstado" class="estado-badge"></div>
            <button class="btn-confirm" onclick="cerrarOverlay()">ENTENDIDO</button>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.1/firebase-app.js";
        import { getFirestore, collection, query, where, getDocs, doc, updateDoc } from "https://www.gstatic.com/firebasejs/10.12.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyApscrKxLaiulk0j3CuxtNr9u_fkLPozro",
            authDomain: "housef-7f6df.firebaseapp.com",
            projectId: "housef-7f6df",
            storageBucket: "housef-7f6df.firebasestorage.app",
            messagingSenderId: "634742667054",
            appId: "1:634742667054:web:d06332cbaf838c55eaecbf"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        // Sistema de Sonidos Electrónicos (Sin voz)
        function sonar(tipo) {
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            
            const now = audioCtx.currentTime;

            if(tipo === 'success') {
                // Sonido "Bip-Bip" ascendente (Aceptado)
                osc.type = 'square';
                osc.frequency.setValueAtTime(440, now);
                osc.frequency.exponentialRampToValueAtTime(880, now + 0.1);
                gain.gain.setValueAtTime(0.1, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
                osc.start(now);
                osc.stop(now + 0.2);
            } else {
                // Sonido "Buzz" grave (Error)
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(150, now);
                gain.gain.setValueAtTime(0.1, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.4);
                osc.start(now);
                osc.stop(now + 0.4);
            }
        }

        async function procesarEscaneo(nombreEscaneado) {
            const overlay = document.getElementById('overlay');
            const resNombre = document.getElementById('resNombre');
            const resEstado = document.getElementById('resEstado');
            const icon = document.getElementById('icon');

            try {
                const q = query(collection(db, "mis_hermanos"), where("nombre", "==", nombreEscaneado));
                const querySnapshot = await getDocs(q);

                overlay.style.display = "flex";
                resNombre.innerText = nombreEscaneado;

                if (!querySnapshot.empty) {
                    const docRef = querySnapshot.docs[0].ref;
                    const datos = querySnapshot.docs[0].data();
                    const estadoActual = datos.estado || "Presente";

                    if (estadoActual === "Presente") {
                        icon.innerHTML = "🚫";
                        resEstado.innerText = "SIN AUTORIZACIÓN";
                        resEstado.style.background = "#fee2e2";
                        resEstado.style.color = "#dc2626";
                        sonar('error');

                    } else if (estadoActual === "Permiso en Proceso") {
                        await updateDoc(docRef, { estado: "Fuera (Con Permiso)" });
                        icon.innerHTML = "✅";
                        resEstado.innerText = "SALIDA EXITOSA";
                        resEstado.style.background = "#dcfce7";
                        resEstado.style.color = "#16a34a";
                        sonar('success');

                    } else if (estadoActual === "Fuera (Con Permiso)") {
                        await updateDoc(docRef, { estado: "Presente" });
                        icon.innerHTML = "🏠";
                        resEstado.innerText = "RETORNO CONFIRMADO";
                        resEstado.style.background = "#e0f2fe";
                        resEstado.style.color = "#0369a1";
                        sonar('success');
                    }
                } else {
                    icon.innerHTML = "⚠️";
                    resNombre.innerText = "NO ENCONTRADO";
                    resEstado.innerText = "USUARIO INVÁLIDO";
                    resEstado.style.background = "#f5f5f5";
                    sonar('error');
                }
            } catch (e) { console.error(e); }
        }

        const html5QrCode = new Html5Qrcode("reader");
        html5QrCode.start({ facingMode: "environment" }, { fps: 25, qrbox: 250 }, (text) => {
            html5QrCode.pause(true);
            procesarEscaneo(text);
        });

        window.cerrarOverlay = () => {
            document.getElementById('overlay').style.display = "none";
            html5QrCode.resume();
        };
    </script>
</body>
</html>
